#!/bin/sh
# Format staged Go files with gofmt before commit.

STAGED=$(git diff --cached --name-only --diff-filter=ACM | grep '\.go$' || true)
if [ -z "$STAGED" ]; then
  exit 0
fi

UNFORMATTED=$(echo "$STAGED" | xargs gofmt -l)
if [ -n "$UNFORMATTED" ]; then
  echo "$STAGED" | xargs gofmt -w
  echo "gofmt: formatted the following files:"
  echo "$UNFORMATTED" | sed 's/^/  /'
  echo "Re-staging formatted files..."
  echo "$UNFORMATTED" | xargs git add
fi

STAGED_FRONTEND=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.(js|html|css)$' || true)
if [ -n "$STAGED_FRONTEND" ]; then
  echo "$STAGED_FRONTEND" | xargs bunx prettier --write
  echo "prettier: formatted the following files:"
  echo "$STAGED_FRONTEND" | sed 's/^/  /'
  echo "Re-staging formatted files..."
  echo "$STAGED_FRONTEND" | xargs git add
fi

exit 0
