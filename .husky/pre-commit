#!/bin/sh
# Format staged Go files with gofmt before commit.

STAGED=$(git diff --cached --name-only --diff-filter=ACM | grep '\.go$')
if [ -z "$STAGED" ]; then
  exit 0
fi

UNFORMATTED=$(echo "$STAGED" | xargs gofmt -l)
if [ -n "$UNFORMATTED" ]; then
  echo "$STAGED" | xargs gofmt -w
  echo "gofmt: formatted the following files:"
  echo "$UNFORMATTED" | sed 's/^/  /'
  echo "Re-staging formatted files..."
  echo "$UNFORMATTED" | xargs git add
fi

exit 0
